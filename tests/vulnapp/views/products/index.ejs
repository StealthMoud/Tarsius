<%- include('../layout/header') %>

    <h2>product catalog</h2>

    <div class="card" style="margin-bottom: 20px;">
        <form action="/products" method="get" style="display: flex; gap: 10px;">
            <input type="text" name="search" placeholder="Search products..." value="<%= search || '' %>"
                style="flex-grow: 1; padding: 5px;">
            <button type="submit" style="padding: 5px 15px;">Search</button>
        </form>
    </div>

    <% if (search) { %>
        <p class="vuln-marker">
            <span class="vuln-badge">Vulnerable to Reflected XSS & Union-Based SQLi</span><br />
            search results for: <strong><%- search %></strong>
        </p>
        <% } %>

            <% if (products && products.length> 0) { %>
                <% products.forEach(function(product) { %>
                    <div class="card">
                        <h3><a href="/products/<%= product.id %>">
                                <%= product.name %>
                            </a></h3>
                        <p>$<%= product.price %>
                        </p>
                    </div>
                    <% }); %>
                        <% } else { %>
                            <p>no products found.</p>
                            <% } %>

                                <%- include('../layout/footer') %>