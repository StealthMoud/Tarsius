<%- include('../layout/header') %>

    <div class="vuln-marker" style="padding: 10px; margin-bottom: 15px;">
        <span class="vuln-badge">Vulnerable to Blind SQL Injection</span>
        <p>The ID parameter in the URL (<code>/products/<%= product.id %></code>) is vulnerable to time-based and
            boolean-based blind SQLi.</p>
    </div>

    <h2>
        <%= product.name %>
    </h2>
    <p>price: $<%= product.price %>
    </p>
    <p>
        <%= product.description %>
    </p>

    <div class="card vuln-marker">
        <span class="vuln-badge">Vulnerable to OS Command Injection</span>
        <h3>refresh stock status</h3>
        <form action="/products/<%= product.id %>/refresh-stock" method="post">
            <label>stock server ip:</label>
            <input type="text" name="ip" value="127.0.0.1" />
            <button type="submit">ping stock db</button>
        </form>
    </div>

    <div class="card vuln-marker">
        <span class="vuln-badge">Vulnerable to Stored XSS</span>
        <h3>reviews</h3>
        <% if (comments && comments.length> 0) { %>
            <% comments.forEach(function(comment) { %>
                <div style="border-bottom: 1px solid #ddd; margin-bottom: 1rem; padding-bottom: 0.5rem;">
                    <strong>
                        <%= comment.username %>
                    </strong> says:
                    <!-- intentionally rendering unescaped html for stored xss demo -->
                    <p><%- comment.comment %></p>
                </div>
                <% }); %>
                    <% } else { %>
                        <p>no reviews yet. be the first!</p>
                        <% } %>
    </div>

    <div class="card">
        <h3>add a review</h3>
        <form action="/products/<%= product.id %>/comments" method="post">
            <textarea name="comment" rows="4" style="width: 100%; border:1px solid #ccc;"></textarea><br />
            <button type="submit">post review</button>
        </form>
    </div>

    <%- include('../layout/footer') %>