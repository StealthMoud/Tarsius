@startuml scanning_flow
autonumber

actor User
participant "Tarsius CLI" as CLI
participant "Async Crawler" as Crawler
participant "Scanner Engine" as Scanner
participant "External Engines" as External
database "SQLite Store" as DB
participant "Report Engine" as Reporter

User -> CLI : Run Scan (e.g. `docker run ... --external`)
activate CLI

CLI -> Crawler : Initialize Crawl (Target URL, Depth)
activate Crawler

loop "For each Discovered URL"
    Crawler -> Crawler : Parse HTML/JS (Find Links/Forms/Assets)
    Crawler -> Crawler : Map Architecture (Detect CMS, Frameworks)
end

Crawler -> CLI : Return Mapped Scope & Target List
deactivate Crawler

CLI -> Scanner : Begin Attack Phase
activate Scanner

par "Native Node.js Attacks (Concurrent)"
    loop "Over all Targets (Threads: 16)"
        Scanner -> Scanner : Mutate Parameters (SQLi, XSS, SSRF...)
        Scanner -> DB : Log Identified Vulnerability
    end
else "External Tool Orchestration (if --external enabled)"
    activate External
    Scanner -> External : Trigger ModNuclei
    External -> DB : Stream NDJSON CVE Findings
    
    alt "If WordPress Detected"
        Scanner -> External : Trigger ModWpscan
        External -> External : Spawn Native Ruby WPScan
        External -> DB : Parse & Save JSON Findings
    end
    
    alt "If Joomla Detected"
        Scanner -> External : Trigger ModJoomscan
        External -> External : Spawn Native Perl JoomScan
        External -> DB : Parse & Save ASCII Findings
    end
    deactivate External
end

Scanner -> CLI : Attack Phase Complete
deactivate Scanner

CLI -> Reporter : Generate Professional Report
activate Reporter
DB -> Reporter : Aggregate All Findings
Reporter -> User : Output (HTML/PDF/JSON)
deactivate Reporter

deactivate CLI
@enduml
